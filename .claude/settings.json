      "Bash(grep -nE 'hv_vcpu_exit_exception_t|hv_vcpu_exit_t|syndrome|virtual_address|physical_address|hv_exit_reason_t reason' __CMDSUB_OUTPUT__/System/Library/Frameworks/Hypervisor.framework/Headers/hv_vcpu_types.h)",
