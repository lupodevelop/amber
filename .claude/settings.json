      "Bash(gunzip -c payload.gz)",
      "Bash(xxd -s 0x38 -l 4 Image)",
      "Bash(xxd -s 0x08 -l 16 Image)",
      "Bash(./target/release/amber boot *)",
      "Bash(echo \"exit code: $?\")",
