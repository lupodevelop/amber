#!/bin/busybox sh
/bin/busybox --install -s /bin
export PATH=/bin
mount -t proc proc /proc
mount -t sysfs sysfs /sys
mount -t devtmpfs dev /dev 2>/dev/null
# PL011 is earlycon-only for now (no full ttyAMA0), so send output to the
# kernel log; earlycon prints it to amber's stdout.
exec >/dev/kmsg 2>&1
echo "amber: ====== guest userspace up ======"
echo "amber: $(uname -a)"
echo "amber: date $(date)"
echo "amber: uptime$(cat /proc/uptime)"
echo "amber: timer irqs ->"; grep -iE 'tick|timer|virt' /proc/interrupts
echo "amber: sleep 2s to prove the timer..."
sleep 2
echo "amber: woke; uptime$(cat /proc/uptime)"
echo "amber: ====== poweroff ======"
poweroff -f
