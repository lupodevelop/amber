# resin overlay — applied on top of Alpine's linux-virt config plus a generated
# "subtraction" fragment (see scripts/build-kernel.sh).
#
# Strategy: keep Alpine's built-in (=y) set exactly — it is a lean, proven virt
# guest base that boots fast — and turn modules off. The subtraction fragment
# disables every Alpine =m (so module-off doesn't silently promote them all to
# built-in and bloat the image); this overlay then pins the handful amber needs
# back on as =y. Result: Alpine's base + amber's devices, nothing else.

# No loadable modules.
# CONFIG_MODULES is not set

# The devices amber drives, built in (also forced by the subtraction fragment;
# restated here so this file documents amber's hard requirements on its own).
CONFIG_VIRTIO=y
CONFIG_VIRTIO_MMIO=y
CONFIG_VIRTIO_BLK=y
CONFIG_VIRTIO_NET=y
CONFIG_VIRTIO_BALLOON=y
CONFIG_HW_RANDOM=y
CONFIG_HW_RANDOM_VIRTIO=y
CONFIG_FAILOVER=y
CONFIG_NET_FAILOVER=y

# Root (squashfs base, gzip -> zlib) + tmpfs overlay, built in.
CONFIG_SQUASHFS=y
CONFIG_SQUASHFS_ZLIB=y
CONFIG_OVERLAY_FS=y

# Console + the gzipped-cpio initramfs amber builds.
CONFIG_SERIAL_AMBA_PL011=y
CONFIG_SERIAL_AMBA_PL011_CONSOLE=y
CONFIG_BLK_DEV_INITRD=y
CONFIG_RD_GZIP=y

# KASLR off: a runtime PC equals its link address (so System.map resolves a boot
# hang) and self-relocation is one less variable on amber's minimal HVF backend.
# CONFIG_RANDOMIZE_BASE is not set
