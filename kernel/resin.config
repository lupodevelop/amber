# resin overlay — applied on top of Alpine's linux-virt config
# (kernel/alpine-virt.config), a proven QEMU/virt guest config for the same
# virtio-mmio + GICv2 + PL011 machine amber emulates.
#
# The defining change: no loadable modules. Alpine ships virtio/squashfs/overlay
# as modules (=m); we fold exactly the ones amber needs into the kernel (=y) and
# turn CONFIG_MODULES off, which drops every other =m driver (DRM, sound, ...) —
# that is the trim, for free, from a config already tuned for a virt guest.

# Built-in everything, no loadable modules.
# CONFIG_MODULES is not set

# --- the devices amber drives: promote from =m to =y ---
CONFIG_VIRTIO=y
CONFIG_VIRTIO_MENU=y
CONFIG_VIRTIO_MMIO=y
CONFIG_VIRTIO_BLK=y
CONFIG_VIRTIO_NET=y
CONFIG_VIRTIO_BALLOON=y
CONFIG_HW_RANDOM=y
CONFIG_HW_RANDOM_VIRTIO=y
CONFIG_FAILOVER=y
CONFIG_NET_FAILOVER=y

# --- root (squashfs base, gzip -> zlib) + tmpfs overlay, built-in ---
CONFIG_SQUASHFS=y
CONFIG_SQUASHFS_ZLIB=y
CONFIG_OVERLAY_FS=y
CONFIG_TMPFS=y
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y

# --- console + the gzipped-cpio initramfs amber builds (restate, to be safe) ---
CONFIG_SERIAL_AMBA_PL011=y
CONFIG_SERIAL_AMBA_PL011_CONSOLE=y
CONFIG_BLK_DEV_INITRD=y
CONFIG_RD_GZIP=y
